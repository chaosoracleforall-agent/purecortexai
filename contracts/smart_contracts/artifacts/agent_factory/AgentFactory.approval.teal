#pragma version 11
#pragma typetrack false

// algopy.arc4.ARC4Contract.approval_program() -> uint64:
main:
    intcblock 0 1 2 8
    bytecblock "cortex_token" 0x151f7c75 "agent_supplies" "latest_asset_id" "BASE_PRICE" "SLOPE"
    txn ApplicationID
    bnz main_after_if_else@2
    // smart_contracts/agent_factory/contract.py:19
    // self.latest_asset_id = UInt64(0)
    bytec_3 // "latest_asset_id"
    intc_0 // 0
    app_global_put
    // smart_contracts/agent_factory/contract.py:20
    // self.cortex_token = UInt64(0)
    bytec_0 // "cortex_token"
    intc_0 // 0
    app_global_put
    // smart_contracts/agent_factory/contract.py:21
    // self.BASE_PRICE = UInt64(10_000)
    bytec 4 // "BASE_PRICE"
    pushint 10000
    app_global_put
    // smart_contracts/agent_factory/contract.py:22
    // self.SLOPE = UInt64(1_000)
    bytec 5 // "SLOPE"
    pushint 1000
    app_global_put

main_after_if_else@2:
    // smart_contracts/agent_factory/contract.py:16
    // class AgentFactory(ARC4Contract):
    txn NumAppArgs
    bz main___algopy_default_create@13
    txn OnCompletion
    !
    assert
    txn ApplicationID
    assert
    pushbytess 0x3a1a5067 0xdf6eb47a 0x850a18f3 0x707b5551 // method "bootstrap_protocol()uint64", method "create_agent(axfer,string,string)uint64", method "calculate_buy_price(uint64,uint64)uint64", method "buy_tokens(pay,uint64,uint64)void"
    txna ApplicationArgs 0
    match bootstrap_protocol create_agent calculate_buy_price buy_tokens
    err

main___algopy_default_create@13:
    txn OnCompletion
    !
    txn ApplicationID
    !
    &&
    return


