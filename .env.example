# PURECORTEX Environment Variables
# Copy to .env and fill in values.
# Generate secrets: openssl rand -base64 32

# ==== AI API Keys (REQUIRED) ====
# https://console.anthropic.com/
CLAUDE_API_KEY=
# https://aistudio.google.com/
GEMINI_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ==== Optional AI Model Overrides ====
CLAUDE_MODEL=claude-opus-4-6
GEMINI_MODEL=gemini-2.5-pro
OPENAI_MODEL=gpt-5
OPENAI_FALLBACK_MODEL=gpt-4.1

# ==== Twitter/X API (REQUIRED for social agent) ====
# https://developer.twitter.com/
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ==== Farcaster (optional) ====
FARCASTER_MNEMONIC=

# ==== Redis (REQUIRED) ====
# Generate: openssl rand -base64 32
REDIS_PASSWORD=

# ==== Security (REQUIRED) ====
# Generate: openssl rand -hex 32
SANDBOX_ESCALATION_TOKEN=
PURECORTEX_BOOTSTRAP_TOKEN=

# ==== Admin/Auth (optional but recommended) ====
# Optional legacy header for emergency admin access after bootstrap.
# Day-to-day key management should use an admin-tier API key.
PURECORTEX_ADMIN_SECRET=
CHAT_SESSION_TTL_SECONDS=900
