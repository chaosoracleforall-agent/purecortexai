    "/api/governance/proposals/{proposal_id}": {
      "get": {
        "tags": [
          "governance"
        ],
        "summary": "Get Proposal",
        "description": "Get a single proposal by ID.",
        "operationId": "get_proposal_api_governance_proposals__proposal_id__get",
        "parameters": [
          {
            "name": "proposal_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Proposal Id"
            }
