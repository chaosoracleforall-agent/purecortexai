                  "$ref": "#/components/schemas/ConstitutionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/governance/overview": {
      "get": {
        "tags": [
          "governance"
        ],
        "summary": "Get Governance Overview",
