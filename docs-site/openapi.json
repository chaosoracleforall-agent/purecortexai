    },
    "/api/transparency/governance": {
      "get": {
        "tags": [
          "transparency"
        ],
        "summary": "Get Governance Transparency",
        "description": "Governance overview \u2014 proposals, participation, and veCORTEX totals.",
        "operationId": "get_governance_transparency_api_transparency_governance_get",
        "responses": {
          "200": {
            "description": "Successful Response",
