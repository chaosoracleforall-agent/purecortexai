# Dedicated signer image
FROM python:3.12.3-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-signer.txt .
RUN pip install --no-cache-dir -r requirements-signer.txt

COPY src ./src

CMD ["python", "-m", "src.services.signer_daemon"]
